DJANGO_SECRET_KEY=change-this-to-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sms.example.com,www.sms.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://sms.example.com,https://www.sms.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_LOG_LEVEL=INFO
SMS_LOG_LEVEL=INFO

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.com

DB_ENGINE=mysql
MYSQL_DATABASE=sms_pro
MYSQL_USER=sms_pro_user
MYSQL_PASSWORD=change-this-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False
CELERY_WORKER_PREFETCH_MULTIPLIER=1

SMS_API_BASE_URL=https://universe.ivoiresoftservices.net
SMS_API_CLIENT_ID=
SMS_API_CLIENT_SECRET=
SMS_API_KEY_BASE64=
SMS_API_FROM=
